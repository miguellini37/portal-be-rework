PORT=3001

# Database
DB_ENDPOINT=<Ask>
DB_USER=<Ask>
DB_PASSWORD=<Ask>
DB_NAME=<Ask>

# Auth (Deprecated - now using Keycloak)
# ACCESS_TOKEN_SECRET=<Ask>
# REFRESH_TOKEN_SECRET=<Ask>

# Keycloak Docker Compose Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=strongpassword123
KEYCLOAK_DB_NAME=keycloak-local

# Keycloak SMTP (Google Workspace — used for email verification)
# Create noreply@portaljobs.net in Google Workspace Admin, then generate
# an App Password (Google Account → Security → App Passwords) if 2FA is on.
KEYCLOAK_SMTP_USER=noreply@portaljobs.net
KEYCLOAK_SMTP_PASSWORD=<App Password from Google Workspace>
# Require email verification for new accounts (true/false)
KEYCLOAK_VERIFY_EMAIL=false

# Backend SMTP (uses same credentials as Keycloak by default)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=  (falls back to KEYCLOAK_SMTP_USER)
# SMTP_PASSWORD=  (falls back to KEYCLOAK_SMTP_PASSWORD)
# SMTP_FROM=noreply@portaljobs.net

# Keycloak Client Configuration for Backend
# KEYCLOAK_CLIENT_SECRET is also injected into the realm JSON via keycloak-config-cli
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=portal-jobs
KEYCLOAK_CLIENT_ID=portal-backend
KEYCLOAK_CLIENT_SECRET=<Ask>
