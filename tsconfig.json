{
  "compilerOptions": {
    "target": "ES2020",                // modern JS target
    "module": "CommonJS",              // Node uses CommonJS modules
    "outDir": "./dist",                // compiled JS output folder
    "rootDir": "./src",                // TS source folder
    "strict": true,                   // enable strict type checking
    "esModuleInterop": true,          // allow import of CommonJS modules
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"]
}
