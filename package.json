{
  "name": "portal-backend",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/Portal-Jobs/portal-backend.git",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node --transpile-only ./src/index.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "typeorm migration:generate src/migrations/migration -d src/config/db.ts  --pretty",
    "migration:run": "typeorm migration:run -d src/config/db.ts",
    "migration:revert": "typeorm migration:revert -d src/config/db.ts",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "prepare": "husky",
    "start:keycloak": "docker compose -f docker-compose.keycloak.dev.yml --env-file .env up -d"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "6.0.1",
    "@fastify/under-pressure": "^9.0.3",
    "@keycloak/keycloak-admin-client": "^26.4.2",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.12",
    "@types/lodash": "^4.17.21",
    "@types/passport-jwt": "^4.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.5.0",
    "fastify": "5.4.0",
    "fastify-qs": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "keycloak-connect": "^26.1.1",
    "lodash": "^4.17.21",
    "ms": "^2.1.3",
    "mysql2": "^3.14.1",
    "nest-keycloak-connect": "^1.10.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.18",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-config-xo": "^0.47.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.0",
    "lint-staged": "^16.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "yarn lint:fix",
      "git add"
    ]
  },
  "typeorm": {
    "cli": {
      "migrationsDir": "src/migration"
    }
  }
}
